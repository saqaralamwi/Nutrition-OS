{
  "expo": {
    "name": "التغذية السريرية",
    "slug": "clinical-nutrition-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "clinical-nutrition",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "يستخدم هذا التطبيق الكاميرا لتصوير المستندات الطبية."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B6B4A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.clinical.nutrition.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "يستخدم التطبيق معرض الصور لرفع تقارير التحاليل الطبية.",
          "cameraPermission": "يستخدم التطبيق الكاميرا لتصوير تقارير التحاليل الطبية مباشرة."
        }
      ],
      [
        "rn-mlkit-ocr",
        {
          "ocrModels": ["latin"],
          "ocrUseBundled": true
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false,
        "root": "./app"
      },
      "eas": {
        "projectId": "75cbdc8b-145f-40b3-9962-3efaa7977257"
      }
    }
  }
}
