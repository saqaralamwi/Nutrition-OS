{
  "expo": {
    "name": "ADCN",
    "slug": "clinical-nutrition-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "clinical-nutrition",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alumawi.clinicaladcn",
      "infoPlist": {
        "NSCameraUsageDescription": "يستخدم هذا التطبيق الكاميرا لتصوير تقارير التحاليل الطبية والمستندات السريرية واستخراج البيانات عبر الماسح الضوئي.",
        "NSPhotoLibraryUsageDescription": "يستخدم هذا التطبيق معرض الصور لتمكين رفع وقراءة تقارير التحاليل الطبية والمستندات السريرية.",
        "NSPhotoLibraryAddUsageDescription": "يستخدم هذا التطبيق معرض الصور لحفظ التقارير الطبية والمستندات المصدرة."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.alumawi.clinicaladcn",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "يستخدم التطبيق معرض الصور لرفع تقارير التحاليل الطبية.",
          "cameraPermission": "يستخدم التطبيق الكاميرا لتصوير تقارير التحاليل الطبية مباشرة."
        }
      ],
      [
        "rn-mlkit-ocr",
        {
          "ocrModels": ["latin"],
          "ocrUseBundled": true
        }
      ],
    ],
    "extra": {
      "router": {
        "origin": false,
        "root": "./app"
      },
      "eas": {
        "projectId": "75cbdc8b-145f-40b3-9962-3efaa7977257"
      }
    }
  }
}
